EXPO_PUBLIC_SYNC_SERVER_URL=http://localhost:4000
EXPO_PUBLIC_WEB_SYNC_SERVER_URL=https://api.philly-tours.com
EXPO_PUBLIC_IOS_APP_STORE_URL=https://apps.apple.com/us/app/your-app/id0000000000
EXPO_PUBLIC_ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.founders.phillyartours
EXPO_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=your_turnstile_site_key
CLOUDFLARE_TURNSTILE_SECRET_KEY=your_turnstile_secret_key

FAL_KEY=your_fal_key
FAL_DEFAULT_MODEL=fal-ai/flux/dev
FAL_DEFAULT_IMAGE_SIZE=landscape_4_3
FAL_DEFAULT_OUTPUT_FORMAT=jpeg

STABILITY_API_KEY=your_stability_key
STABILITY_DEFAULT_ENDPOINT=core
STABILITY_DEFAULT_ASPECT_RATIO=3:2
STABILITY_DEFAULT_OUTPUT_FORMAT=png

REPLICATE_API_TOKEN=r8_xxx
REPLICATE_DEFAULT_MODEL=black-forest-labs/flux-1.1-pro
REPLICATE_DEFAULT_ASPECT_RATIO=3:2
REPLICATE_DEFAULT_OUTPUT_FORMAT=png

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=... # only if using temporary STS credentials
POLLY_DEFAULT_VOICE_ID=Amy
POLLY_DEFAULT_ENGINE=neural

ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=400

EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
AUTH_JWT_SECRET=replace_with_long_random_server_secret
BUILDER_ADMIN_ACCOUNTS_JSON='[]'
RESEND_API_KEY=re_xxx
NEWSLETTER_FROM_EMAIL="Philly Tours <newsletter@philly-tours.com>"
# ALLOW_LEGACY_ADMIN_API_KEY=true # development-only compatibility switch
# ADMIN_API_KEY=replace_with_admin_delete_key

EXPO_PUBLIC_IAP_PLUS_IOS=com.founders.phillyartours.plus
EXPO_PUBLIC_IAP_PRO_IOS=com.founders.phillyartours.pro
EXPO_PUBLIC_IAP_PLUS_ANDROID=com.founders.phillyartours.plus
EXPO_PUBLIC_IAP_PRO_ANDROID=com.founders.phillyartours.pro

APPLE_IAP_BUNDLE_ID=com.founders.phillyartours
APPLE_IAP_ISSUER_ID=your-issuer-id
APPLE_IAP_KEY_ID=your-key-id
APPLE_IAP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----"
APPLE_IAP_ENV=sandbox

GOOGLE_PLAY_PACKAGE_NAME=com.founders.phillyartours
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# GOOGLE_SERVICE_ACCOUNT_FILE=/absolute/path/to/google-service-account.json

# Meta Wearables DAT iOS project values
# These are not Expo public values. Add them to the iOS target build settings
# (or an xcconfig) before pairing Meta glasses on device.
META_WEARABLES_APP_ID=your-meta-app-id
META_WEARABLES_CLIENT_TOKEN=your-meta-client-token
META_WEARABLES_APP_LINK_URL_SCHEME=com.founders.phillyartours
