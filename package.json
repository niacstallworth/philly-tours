{
  "name": "philly-ar-tours",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "metro": "expo start -c --port 8081",
    "metro:dev-client": "expo start --dev-client -c --port 8081",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --port 8081",
    "web": "expo start --web",
    "ar:catalog:import": "node scripts/import-ar-asset-catalog.mjs",
    "ar:briefs:generate": "node scripts/generate-ar-briefs.mjs",
    "ar:manifests:generate": "node scripts/generate-ar-scene-manifests.mjs",
    "ar:tuning:apply": "node scripts/apply-ar-tuning-snapshot.mjs",
    "narration:map": "node scripts/generate-narration-audio-map.mjs && node scripts/generate-narration-runtime-catalog.mjs",
    "narration:catalog:runtime": "node scripts/generate-narration-runtime-catalog.mjs",
    "narration:scripts:map": "node scripts/generate-narration-script-map.mjs",
    "narration:claude": "node scripts/generate-claude-narration-catalog.mjs",
    "narration:import": "node scripts/import-narration-catalog-parts.mjs",
    "narration:normalize": "node scripts/normalize-narration-catalog.mjs",
    "narration:seed:missing": "node scripts/seed-missing-narration-catalog.mjs",
    "narration:polly": "node scripts/generate-polly-narration.mjs",
    "sync-server": "node server/sync-server.js",
    "stripe:listen": "stripe listen --events checkout.session.completed,checkout.session.expired,payment_intent.succeeded,payment_intent.payment_failed --forward-to http://localhost:4000/api/stripe/webhook"
  },
  "dependencies": {
    "@aws-sdk/client-polly": "^3.1009.0",
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@stripe/stripe-react-native": "0.45.0",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "expo": "~53.0.0",
    "expo-asset": "~11.1.7",
    "expo-av": "~15.1.7",
    "expo-clipboard": "~7.1.5",
    "expo-constants": "~17.1.8",
    "expo-location": "~18.1.5",
    "expo-speech": "~13.1.7",
    "expo-status-bar": "~2.2.3",
    "expo-web-browser": "~14.2.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "google-auth-library": "^10.6.1",
    "jose": "^6.2.0",
    "jsonwebtoken": "^9.0.3",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-maps": "1.20.1",
    "react-native-nitro-modules": "^0.31.10",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-webview": "^13.13.5",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "stripe": "^20.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  }
}
