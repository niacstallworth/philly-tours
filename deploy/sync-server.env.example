PORT=4000
NODE_ENV=production

# Public mobile app/backend URL
EXPO_PUBLIC_SYNC_SERVER_URL=https://api.philly-tours.com

# Browser builds use the public sync hostname too.
EXPO_PUBLIC_WEB_SYNC_SERVER_URL=https://api.philly-tours.com

# Cloudflare Turnstile
EXPO_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=your_turnstile_site_key
CLOUDFLARE_TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# Production auth
AUTH_JWT_SECRET=replace_with_a_long_random_secret
BUILDER_ADMIN_ACCOUNTS_JSON='[]'

# Keep this disabled in production unless you are actively doing a short-lived migration.
# ALLOW_LEGACY_ADMIN_API_KEY=false

# Database
SUPABASE_DB_URL=postgresql://postgres.example:password@db.example.com:5432/postgres?sslmode=require

# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Google Maps Platform
GOOGLE_MAPS_API_KEY=your_google_maps_platform_server_key
GOOGLE_MAPS_DEFAULT_REGION=us
GOOGLE_MAPS_DEFAULT_LANGUAGE=en

# Apple / Google verification
APPLE_IAP_BUNDLE_ID=com.founders.phillyartours
APPLE_IAP_ISSUER_ID=replace_me
APPLE_IAP_KEY_ID=replace_me
APPLE_IAP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_me\n-----END PRIVATE KEY-----"
APPLE_IAP_ENV=production
GOOGLE_PLAY_PACKAGE_NAME=com.founders.phillyartours
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"replace_me"}
